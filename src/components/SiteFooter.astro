---
const year = new Date().getFullYear();
---
<footer class="px-6 py-24 bg-night text-fox-cream">
  <div class="max-w-7xl mx-auto">
    <div class="grid md:grid-cols-4 gap-12 md:gap-10 mb-16">

      <div class="md:col-span-2">
        <p class="font-display font-light text-4xl md:text-5xl text-snow mb-5 tracking-tight">Red Fox Inn</p>
        <p class="font-display font-light italic text-lg md:text-xl text-fox-amber mb-10 max-w-md leading-relaxed">
          Clever, caring, independent,<br />and at home with the wild.
        </p>
        <div class="font-body text-sm space-y-1 font-light leading-relaxed">
          <p>112 Main Street</p>
          <p>Lancaster, NH 03584</p>
        </div>
        <div class="font-body text-sm mt-5 space-y-1">
          <p><a href="tel:+16037884921" class="hover:text-fox-amber transition-colors">(603) 788&#8209;4921</a></p>
          <p><a href="mailto:stay@redfoxinnnh.com" class="hover:text-fox-amber transition-colors">stay@redfoxinnnh.com</a></p>
        </div>
        <p class="font-body text-xs mt-6 font-light text-fox-cream/70 leading-relaxed max-w-sm">
          Lobby open 7:30 AM &ndash; 9:00 PM.<br />Complimentary Wayfarer coffee + continental breakfast.
        </p>
      </div>

      <div>
        <p class="font-body uppercase text-xs tracking-[0.25em] text-fox-orange mb-5 font-medium">Visit</p>
        <ul class="font-body text-sm space-y-2.5 font-light">
          <li><a href="/stay/" class="hover:text-snow transition-colors">Stay</a></li>
          <li><a href="/experience/" class="hover:text-snow transition-colors">Experience</a></li>
          <li><a href="/gather/" class="hover:text-snow transition-colors">Gather &amp; Events</a></li>
          <li><a href="/the-den/" class="hover:text-snow transition-colors">The Den</a></li>
          <li><a href="/the-dusk/" class="hover:text-snow transition-colors">The Dusk</a></li>
          <li><a href="/story/" class="hover:text-snow transition-colors">Our Story</a></li>
          <li><a href="/journal/" class="hover:text-snow transition-colors">Journal</a></li>
        </ul>
      </div>

      <div>
        <p class="font-body uppercase text-xs tracking-[0.25em] text-fox-orange mb-5 font-medium">Connect</p>
        <ul class="font-body text-sm space-y-2.5 font-light">
          <li><a href="/contact/" class="hover:text-snow transition-colors">Contact &amp; Directions</a></li>
          <li><a href="/policies/" class="hover:text-snow transition-colors">Hotel Policies</a></li>
          <li><a href="/book/" class="hover:text-snow transition-colors">Book a Room</a></li>
          <li><a href="https://www.facebook.com" rel="noopener noreferrer" class="hover:text-snow transition-colors">Facebook</a></li>
          <li><a href="https://www.instagram.com" rel="noopener noreferrer" class="hover:text-snow transition-colors">Instagram</a></li>
        </ul>
      </div>

    </div>

    <div class="pt-10 border-t border-fox-brown/60 grid md:grid-cols-2 gap-8 items-end">
      <div>
        <p class="font-body uppercase text-xs tracking-[0.25em] text-fox-orange mb-3 font-medium">Sister Properties</p>
        <p class="font-body text-sm leading-relaxed font-light">
          Also operated by our family &mdash;<br />
          <a href="https://saffroninnme.com" rel="noopener noreferrer" class="underline decoration-fox-orange decoration-1 underline-offset-4 hover:text-snow transition-colors">Saffron Inn</a>
          &nbsp;<span class="text-fox-orange">&middot;</span>&nbsp;
          <a href="https://eastgateinnnh.com" rel="noopener noreferrer" class="underline decoration-fox-orange decoration-1 underline-offset-4 hover:text-snow transition-colors">Eastgate Inn</a>
        </p>
      </div>
      <div class="md:text-right font-body text-xs font-light text-fox-cream/60 space-y-1">
        <p>&copy; {year} Red Fox Inn. Operated by Hanuram, LLC.</p>
        <p>
          <a href="/policies/" class="hover:text-fox-amber transition-colors">Policies</a> &middot;
          <a href="/contact/" class="hover:text-fox-amber transition-colors">Contact</a>
        </p>
      </div>
    </div>
  </div>
</footer>
