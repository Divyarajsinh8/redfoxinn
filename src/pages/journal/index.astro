---
import BaseLayout from '../../layouts/BaseLayout.astro';

interface JournalPost {
  slug: string;
  title: string;
  excerpt: string;
  category: string;
  publishedDate: string;
  readMin: number;
  gradient: string;
}

const posts: JournalPost[] = [
  {
    slug: 'hotels-near-santas-village',
    title: 'Hotels Near Santa’s Village: Your Guide to Staying in Lancaster, NH',
    excerpt: 'Fifteen minutes south of our front door, a Christmas park that’s been running since 1953 still feels exactly like it did the day it opened. Here’s how to do the visit right.',
    category: 'Families · North Country',
    publishedDate: '2026-05-03',
    readMin: 7,
    gradient: 'from-fox-red via-deep-red to-fox-brown',
  },
  {
    slug: 'atv-lodging-ride-the-wilds',
    title: 'ATV Lodging on Ride the Wilds: Park at Your Door in Lancaster, NH',
    excerpt: 'Ride the Wilds is the Northeast’s largest interconnected ATV trail system — 1,000+ miles. Lancaster is one of the few towns where you can ride from the trail to your room.',
    category: 'Motorsports · North Country',
    publishedDate: '2026-05-03',
    readMin: 6,
    gradient: 'from-fox-orange via-fox-red to-fox-brown',
  },
  {
    slug: 'snowmobile-lodging-coos-county',
    title: 'Snowmobile Season in Coös County: Where to Stay, Ride, and Warm Up',
    excerpt: 'The Coös corridor system runs from Quebec down through the White Mountains. Park your sled at your door, fuel up at the bar, do it again tomorrow.',
    category: 'Winter · North Country',
    publishedDate: '2026-05-03',
    readMin: 6,
    gradient: 'from-night via-fox-brown to-forest-green',
  },
  {
    slug: 'lancaster-fair-lodging',
    title: 'The Lancaster Fair: New England’s Oldest Agricultural Tradition',
    excerpt: 'Running every year since 1870. Labor Day weekend draws tens of thousands to the fairgrounds five minutes from our front door. Here’s what to expect — and why you should book early.',
    category: 'Events · Local History',
    publishedDate: '2026-05-03',
    readMin: 5,
    gradient: 'from-fox-amber via-fox-orange to-deep-red',
  },
  {
    slug: 'hiking-4000-footers-lancaster',
    title: '4,000-Footers You Can Hike from Lancaster, NH',
    excerpt: 'New Hampshire has 48 mountains over 4,000 feet — the AMC’s 4,000-Footer Club. Several are reachable from a Lancaster basecamp. Mt. Waumbek, Caps Ridge, the Presidentials.',
    category: 'Hiking · White Mountains',
    publishedDate: '2026-05-03',
    readMin: 8,
    gradient: 'from-forest-green via-forest-sage to-fox-brown',
  },
];

const dateFmt = (iso: string) =>
  new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout
  title="Journal &mdash; Red Fox Inn | Lancaster, NH"
  description="Local guides, seasonal tips, and stories from the North Country. Hotels near Santa&rsquo;s Village, ATV lodging, hiking guides, snowmobile season, and more."
  transparentHeader
>
  <main id="main-content">

    <!-- Hero -->
    <section class="relative bg-fox-brown text-snow px-6 py-32 md:py-44 overflow-hidden -mt-[88px] pt-[140px] md:pt-[180px]">
      <div class="absolute inset-0 bg-gradient-to-br from-forest-green via-fox-brown to-deep-red/50"></div>
      <div class="relative z-10 max-w-4xl mx-auto text-center">
        <p class="font-body text-xs uppercase tracking-[0.4em] text-fox-amber mb-10 font-medium">
          Journal
        </p>
        <h1 class="font-display font-light text-5xl md:text-6xl lg:text-7xl leading-[1.05] mb-8 text-snow">
          Stories from<br />the North Woods.
        </h1>
        <p class="font-display font-light italic text-xl md:text-2xl text-fox-cream max-w-2xl mx-auto leading-[1.5]">
          Trail guides, local history, seasonal picks, and the occasional quiet tip from the lobby.
        </p>
      </div>
    </section>

    <!-- Post grid -->
    <section class="bg-snow px-6 py-20 md:py-28">
      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
          {posts.map((post, i) => (
            <a href={`/journal/${post.slug}/`} class="group block bg-fox-cream overflow-hidden">
              <div class="relative aspect-[4/3] overflow-hidden">
                <div class={`absolute inset-0 bg-gradient-to-br ${post.gradient} transition-transform duration-700 group-hover:scale-[1.04]`}></div>
                <div class="absolute inset-0 bg-gradient-to-t from-night/60 via-night/10 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-5">
                  <p class="font-body text-[0.65rem] uppercase tracking-[0.3em] text-fox-amber font-medium">{post.category}</p>
                </div>
              </div>
              <div class="p-6 md:p-8">
                <p class="font-body text-[0.7rem] uppercase tracking-[0.3em] text-fox-orange-deep mb-3 font-medium">
                  {dateFmt(post.publishedDate)} <span class="text-warm-gray/60 mx-1">·</span> {post.readMin} min read
                </p>
                <h2 class="font-display font-light text-2xl md:text-[1.75rem] leading-[1.2] mb-4 text-fox-brown group-hover:text-fox-red transition-colors">
                  {post.title}
                </h2>
                <p class="font-body font-light text-sm text-warm-gray leading-relaxed">{post.excerpt}</p>
                <p class="font-body text-xs uppercase tracking-[0.25em] text-fox-red mt-5 font-medium">
                  Read &rarr;
                </p>
              </div>
            </a>
          ))}
        </div>

        <div class="text-center mt-20">
          <p class="font-body text-sm text-warm-gray font-light max-w-xl mx-auto">
            More stories on the way. Want them in your inbox? Drop us a line at <a href="mailto:stay@redfoxinnnh.com" class="text-fox-red hover:text-deep-red border-b border-fox-orange">stay@redfoxinnnh.com</a>.
          </p>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
