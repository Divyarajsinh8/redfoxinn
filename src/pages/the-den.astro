---
import BaseLayout from '../layouts/BaseLayout.astro';

const denSchema = {
  '@context': 'https://schema.org',
  '@type': 'BarOrPub',
  '@id': 'https://redfoxinnnh.com/the-den/#bar',
  name: 'The Den',
  alternateName: 'The Den at Red Fox Inn',
  description: 'Cocktail bar inside Red Fox Inn — every fox needs a place to unwind. Classic cocktails, jazz on weekends, speakeasy ambiance in the heart of downtown Lancaster, New Hampshire.',
  url: 'https://redfoxinnnh.com/the-den/',
  telephone: '+1-603-788-4921',
  servesCuisine: 'Cocktails, American small plates',
  priceRange: '$$',
  acceptsReservations: false,
  parentOrganization: { '@id': 'https://redfoxinnnh.com/#hotel' },
  containedInPlace: { '@id': 'https://redfoxinnnh.com/#hotel' },
  address: {
    '@type': 'PostalAddress',
    streetAddress: '112 Main Street',
    addressLocality: 'Lancaster',
    addressRegion: 'NH',
    postalCode: '03584',
    addressCountry: 'US',
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Thursday', 'Friday', 'Saturday', 'Sunday', 'Monday'],
      opens: '17:00',
      closes: '23:00',
    },
  ],
};
---
<BaseLayout
  title="The Den &mdash; Cocktail Bar | Red Fox Inn, Lancaster NH"
  description="Every fox needs a place to unwind. Craft cocktails, live music weekends, speakeasy ambiance in the heart of downtown Lancaster, New Hampshire."
  transparentHeader
  jsonLd={denSchema}
>
  <main id="main-content">

    <!-- Hero -->
    <section class="relative bg-night text-snow px-6 py-40 md:py-56 overflow-hidden -mt-[88px] pt-[160px] md:pt-[200px]">
      <div class="absolute inset-0 bg-gradient-to-br from-night via-deep-red/40 to-fox-brown"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_30%,rgba(28,20,16,0.85)_100%)]"></div>
      <div class="relative z-10 max-w-4xl mx-auto text-center">
        <p class="font-body text-xs uppercase tracking-[0.4em] text-fox-orange mb-10 font-medium">
          The Bar
        </p>
        <h1 class="font-display font-light text-6xl md:text-8xl lg:text-[7rem] leading-[1.05] mb-10 text-snow">
          The Den.
        </h1>
        <p class="font-display font-light italic text-xl md:text-2xl text-fox-amber max-w-3xl mx-auto leading-[1.5]">
          Every fox needs a place to unwind.
        </p>
      </div>
    </section>

    <!-- Body copy -->
    <section class="bg-snow px-6 py-24 md:py-32">
      <div class="max-w-3xl mx-auto">
        <div class="font-body font-light text-lg md:text-xl text-fox-brown leading-[1.75] space-y-8">
          <p>
            A den is where a fox returns after a day in the wild &mdash; warm, sheltered, home. The Den is our cocktail bar, and it serves the same purpose. From martinis to Manhattans, our classic cocktails harken to the gilded days of speakeasy hideaways. Sink into a deep blue velvet chair as jazz-infused music plays while you enjoy a liquid work of art from our signature cocktail menu. Live music on weekends for a date night to remember.
          </p>
          <p class="font-display italic text-2xl md:text-3xl text-fox-red leading-[1.4] pt-4">
            Start your evening here. Finish it next door.
          </p>
        </div>
      </div>
    </section>

    <!-- Why the name (sidebar / pull quote) -->
    <section class="bg-fox-cream px-6 py-24 md:py-32">
      <div class="max-w-5xl mx-auto grid md:grid-cols-[1fr_2fr] gap-10 md:gap-16 items-start">
        <div>
          <p class="font-body text-xs uppercase tracking-[0.3em] text-fox-red mb-3 font-medium">
            Why &ldquo;The Den&rdquo;
          </p>
          <p class="font-display font-light text-3xl md:text-4xl leading-[1.1] text-fox-brown">
            A fox&rsquo;s home base.
          </p>
        </div>
        <div class="font-display font-light italic text-xl md:text-2xl text-fox-brown leading-[1.55] border-l-2 border-fox-orange pl-8 md:pl-10">
          <p>
            &ldquo;In the wild, a den is where a fox goes to rest, to be safe, to be home. We named our bar The Den because that&rsquo;s exactly what it is &mdash; the place you come back to after a day on the trails, the slopes, or the river. Every fox needs one.&rdquo;
          </p>
        </div>
      </div>
    </section>

    <!-- Hours -->
    <section class="bg-snow px-6 py-20 md:py-24">
      <div class="max-w-3xl mx-auto grid md:grid-cols-2 gap-12 md:gap-16">
        <div>
          <p class="font-body text-xs uppercase tracking-[0.3em] text-fox-red mb-5 font-medium">Hours</p>
          <p class="font-display font-light text-2xl md:text-3xl leading-snug text-fox-brown mb-3">Thursday &ndash; Monday</p>
          <p class="font-body font-light text-lg text-warm-gray">5:00 &ndash; 11:00 PM</p>
          <p class="font-body text-xs uppercase tracking-[0.2em] text-warm-gray mt-6 font-medium">21+ only</p>
        </div>
        <div>
          <p class="font-body text-xs uppercase tracking-[0.3em] text-fox-red mb-5 font-medium">Find Us</p>
          <p class="font-body font-light text-lg text-fox-brown leading-relaxed">
            Inside Red Fox Inn<br />112 Main Street<br />Lancaster, NH 03584
          </p>
          <p class="font-body text-sm mt-4">
            <a href="tel:+16037884921" class="text-fox-red hover:text-deep-red border-b border-fox-orange">(603) 788&#8209;4921</a>
          </p>
        </div>
      </div>
    </section>

    <!-- Cross-sell to The Dusk -->
    <section class="bg-fox-brown text-snow px-6 py-20 md:py-28">
      <div class="max-w-4xl mx-auto text-center">
        <p class="font-body text-xs uppercase tracking-[0.3em] text-fox-orange mb-6 font-medium">Next Door</p>
        <h2 class="font-display font-light italic text-3xl md:text-5xl leading-[1.15] mb-8 text-snow">
          Finish the evening<br />at The Dusk.
        </h2>
        <p class="font-body font-light text-base md:text-lg text-fox-cream leading-relaxed mb-10 max-w-xl mx-auto">
          Our cigar lounge next door &mdash; leather chairs, top-shelf bourbon, and a walk-in humidor stocked with Drew Estate, Ashton, Rocky Patel, Fuente, and more.
        </p>
        <a href="/the-dusk/" class="font-body inline-block px-10 py-4 bg-fox-red text-snow text-sm font-medium tracking-[0.15em] uppercase hover:bg-deep-red transition-colors">
          Visit The Dusk
        </a>
      </div>
    </section>

  </main>
</BaseLayout>
