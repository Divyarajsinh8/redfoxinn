---
import BaseLayout from '../layouts/BaseLayout.astro';

const brands = [
  'Drew Estate',
  'Dunbarton',
  'My Father\u2019s Promise',
  'Ashton',
  'Rocky Patel',
  'A. Fuente',
  'Perdomo',
  'De Leon Cigars',
  '7-20-4',
];
---
<BaseLayout
  title="The Waypoint Cigar Lounge &mdash; Red Fox Inn, Lancaster NH"
  description="Leather chairs, a walk-in humidor, and top-shelf bourbon. The Waypoint Cigar Lounge at Red Fox Inn in Lancaster, NH."
  transparentHeader
>
  <main id="main-content">

    <!-- Hero -->
    <section class="relative bg-night text-snow px-6 py-40 md:py-56 overflow-hidden -mt-[88px] pt-[160px] md:pt-[200px]">
      <div class="absolute inset-0 bg-gradient-to-br from-night via-fox-brown to-deep-red/50"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,transparent_30%,rgba(28,20,16,0.85)_100%)]"></div>
      <div class="relative z-10 max-w-4xl mx-auto text-center">
        <p class="font-body text-xs uppercase tracking-[0.4em] text-fox-orange mb-10 font-medium">
          The Lounge
        </p>
        <h1 class="font-display font-light text-5xl md:text-7xl lg:text-[6rem] leading-[1.05] mb-10 text-snow">
          The<br />Waypoint.
        </h1>
        <p class="font-display font-light italic text-xl md:text-2xl text-fox-amber max-w-3xl mx-auto leading-[1.5]">
          A point in space where you can relax and unwind.
        </p>
      </div>
    </section>

    <!-- Copy -->
    <section class="bg-snow px-6 py-24 md:py-32">
      <div class="max-w-3xl mx-auto">
        <div class="font-body font-light text-lg md:text-xl text-fox-brown leading-[1.75] space-y-8">
          <p>
            The smell and taste of satisfaction awaits as you settle into leather chairs with a quality cigar and a top-shelf bourbon. Or create your own unique experience and pair your chosen one with a craft cocktail from <a href="/bar/" class="text-fox-red border-b border-fox-orange hover:text-deep-red hover:border-deep-red transition-colors">The Compass Rose</a> next door.
          </p>
          <p>
            Quality sticks from Drew Estate, Dunbarton, My Father&rsquo;s Promise, Ashton, Rocky Patel, A. Fuente, and Perdomo. Newcomers <em class="font-display">De Leon Cigars</em> and the reinvented <em class="font-display">7-20-4</em> line from our very own New Hampshire. With all the options available, disappointment is not one of them.
          </p>
        </div>
      </div>
    </section>

    <!-- Brand strip -->
    <section class="bg-fox-cream px-6 py-20 md:py-24">
      <div class="max-w-5xl mx-auto">
        <p class="font-body text-xs uppercase tracking-[0.3em] text-fox-red mb-10 font-medium text-center">In the Humidor</p>
        <div class="flex flex-wrap justify-center gap-x-10 gap-y-6">
          {brands.map((b) => (
            <span class="font-display font-light text-2xl md:text-3xl text-fox-brown">{b}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- Hours -->
    <section class="bg-night text-snow px-6 py-20 md:py-24">
      <div class="max-w-3xl mx-auto grid md:grid-cols-2 gap-12 md:gap-16">
        <div>
          <p class="font-body text-xs uppercase tracking-[0.3em] text-fox-orange mb-5 font-medium">Hours</p>
          <p class="font-display font-light text-2xl md:text-3xl leading-snug text-fox-amber mb-3">Thursday &ndash; Monday</p>
          <p class="font-body font-light text-lg text-fox-cream/85">2:00 &ndash; 10:00 PM</p>
          <p class="font-body text-xs uppercase tracking-[0.2em] text-fox-cream/60 mt-6 font-medium">21+ only</p>
        </div>
        <div>
          <p class="font-body text-xs uppercase tracking-[0.3em] text-fox-orange mb-5 font-medium">Find Us</p>
          <p class="font-body font-light text-lg text-fox-cream leading-relaxed">
            Inside Red Fox Inn<br />112 Main Street<br />Lancaster, NH 03584
          </p>
          <p class="font-body text-sm mt-4">
            <a href="tel:+16037884921" class="text-fox-amber hover:text-snow border-b border-fox-orange">(603) 788&#8209;4921</a>
          </p>
        </div>
      </div>
    </section>

    <!-- Cross-sell to Bar -->
    <section class="bg-fox-cream px-6 py-20 md:py-28">
      <div class="max-w-4xl mx-auto text-center">
        <p class="font-body text-xs uppercase tracking-[0.3em] text-fox-red mb-6 font-medium">Next Door</p>
        <h2 class="font-display font-light italic text-3xl md:text-5xl leading-[1.15] mb-8">
          Start the evening<br />at The Compass Rose.
        </h2>
        <p class="font-body font-light text-base md:text-lg text-warm-gray leading-relaxed mb-10 max-w-xl mx-auto">
          Classic cocktails in a jazz-and-velvet setting. Pick up a cigar from the humidor on your way through.
        </p>
        <a href="/bar/" class="font-body inline-block px-10 py-4 bg-fox-red text-snow text-sm font-medium tracking-[0.15em] uppercase hover:bg-deep-red transition-colors">
          Visit the Compass Rose
        </a>
      </div>
    </section>

  </main>
</BaseLayout>
