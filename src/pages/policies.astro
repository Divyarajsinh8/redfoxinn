---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What time is check-in and check-out at Red Fox Inn?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Check-in is 3:00 PM and check-out is 11:00 AM. Early check-in and late check-out are subject to availability — please call (603) 788-4921 to inquire.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the cancellation policy?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Cancellations made more than 72 hours before check-in receive a full refund. Cancellations within 72 hours of check-in are subject to a fee equal to one night’s stay plus tax. No-shows will be charged for the first night plus tax, and the remainder of the reservation will be cancelled.',
      },
    },
    {
      '@type': 'Question',
      name: 'Are pets allowed at Red Fox Inn?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Pets are not permitted in guest rooms, out of respect for guests with allergies. A cleaning fee of $250 will be assessed if this policy is violated. Service animals are welcome in accordance with ADA guidelines.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is smoking allowed at Red Fox Inn?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Red Fox Inn is a 100% non-smoking property. No smoking or vaping of any kind is permitted inside guest rooms, lobbies, or enclosed spaces. A cleaning fee of $250 will be charged for any violation. Designated outdoor smoking areas are available on the property.',
      },
    },
    {
      '@type': 'Question',
      name: 'What identification is required at check-in?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A valid government-issued photo ID is required at check-in. The primary guest must be 21 years of age or older. A valid credit or debit card is also required at check-in for any incidentals.',
      },
    },
    {
      '@type': 'Question',
      name: 'How often are rooms serviced by housekeeping?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'For stays of two nights or fewer, daily housekeeping is not provided — fresh towels and toiletries are available at the front desk on request. For stays of three or more nights, rooms are serviced on the third day. Extended stays of seven or more nights receive weekly housekeeping on a designated day.',
      },
    },
    {
      '@type': 'Question',
      name: 'What taxes apply to room rates?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'All rates are subject to the 9% New Hampshire Meals and Rooms Tax.',
      },
    },
  ],
};
---
<BaseLayout
  title="Policies &mdash; Red Fox Inn"
  description="Check-in, cancellation, and house policies for Red Fox Inn in Lancaster, New Hampshire."
  jsonLd={faqSchema}
>
  <main id="main-content" class="bg-fox-cream">
    <!-- Hero -->
    <section class="px-6 pt-24 pb-16">
      <div class="max-w-3xl mx-auto text-center">
        <p class="font-body text-xs uppercase tracking-[0.3em] text-fox-red mb-6 font-medium">
          Hotel Policies
        </p>
        <h1 class="font-display font-light text-5xl md:text-6xl leading-[1.1] mb-8">
          A few house<br />rules for a good stay.
        </h1>
        <p class="font-body text-lg text-warm-gray leading-relaxed font-light">
          Making a reservation at Red Fox Inn means agreeing to the policies below. They&rsquo;re here to keep the stay comfortable and fair for everyone &mdash; please take a moment to read through them before you book.
        </p>
      </div>
    </section>

    <!-- Policy sections -->
    <div class="max-w-3xl mx-auto px-6 pb-24 space-y-16">

      <section>
        <p class="font-body text-xs uppercase tracking-[0.25em] text-fox-orange mb-4 font-medium">01</p>
        <h2 class="font-display font-light text-3xl md:text-4xl mb-6 leading-tight">Check-In &amp; Check-Out</h2>
        <ul class="font-body text-base leading-relaxed space-y-3 text-fox-brown font-light">
          <li><span class="font-medium">Check-in:</span> 3:00 PM</li>
          <li><span class="font-medium">Check-out:</span> 11:00 AM</li>
          <li>A valid government-issued photo ID is required at check-in. The primary guest must be 21 years of age or older.</li>
          <li>A valid credit or debit card is required at check-in for any incidentals.</li>
          <li>Early check-in and late check-out are subject to availability &mdash; please call <a href="tel:+16037884921" class="text-fox-red hover:text-deep-red border-b border-fox-orange">(603) 788&#8209;4921</a> to inquire.</li>
        </ul>
      </section>

      <section>
        <p class="font-body text-xs uppercase tracking-[0.25em] text-fox-orange mb-4 font-medium">02</p>
        <h2 class="font-display font-light text-3xl md:text-4xl mb-6 leading-tight">Reservation &amp; Payment</h2>
        <ul class="font-body text-base leading-relaxed space-y-3 text-fox-brown font-light">
          <li>Full payment is collected at the time of check-in.</li>
          <li>A pre-authorization hold may be placed on your card at the time of booking to confirm the reservation.</li>
          <li>All rates are subject to the 9% New Hampshire Meals &amp; Rooms Tax.</li>
        </ul>
      </section>

      <section>
        <p class="font-body text-xs uppercase tracking-[0.25em] text-fox-orange mb-4 font-medium">03</p>
        <h2 class="font-display font-light text-3xl md:text-4xl mb-6 leading-tight">Cancellation</h2>
        <ul class="font-body text-base leading-relaxed space-y-3 text-fox-brown font-light">
          <li>Cancellations made more than 72 hours before check-in receive a full refund.</li>
          <li>Cancellations made within 72 hours of check-in are subject to a fee equal to one night&rsquo;s stay plus tax.</li>
          <li>No-shows will be charged for the first night plus tax, and the remainder of the reservation will be cancelled.</li>
        </ul>
      </section>

      <section>
        <p class="font-body text-xs uppercase tracking-[0.25em] text-fox-orange mb-4 font-medium">04</p>
        <h2 class="font-display font-light text-3xl md:text-4xl mb-6 leading-tight">Smoking</h2>
        <ul class="font-body text-base leading-relaxed space-y-3 text-fox-brown font-light">
          <li>Red Fox Inn is a 100% non-smoking property. No smoking or vaping of any kind is permitted inside guest rooms, lobbies, or enclosed spaces.</li>
          <li>A cleaning fee of $250 will be charged for any violation.</li>
          <li>Designated outdoor smoking areas are available on the property.</li>
        </ul>
      </section>

      <section>
        <p class="font-body text-xs uppercase tracking-[0.25em] text-fox-orange mb-4 font-medium">05</p>
        <h2 class="font-display font-light text-3xl md:text-4xl mb-6 leading-tight">Pets</h2>
        <ul class="font-body text-base leading-relaxed space-y-3 text-fox-brown font-light">
          <li>Pets are not permitted in guest rooms, out of respect for guests with allergies.</li>
          <li>A cleaning fee of $250 will be assessed if this policy is violated.</li>
          <li>Service animals are welcome in accordance with ADA guidelines.</li>
        </ul>
      </section>

      <section>
        <p class="font-body text-xs uppercase tracking-[0.25em] text-fox-orange mb-4 font-medium">06</p>
        <h2 class="font-display font-light text-3xl md:text-4xl mb-6 leading-tight">Room Conduct</h2>
        <ul class="font-body text-base leading-relaxed space-y-3 text-fox-brown font-light">
          <li><span class="font-medium">Quiet hours:</span> 10:00 PM &ndash; 7:00 AM daily.</li>
          <li>No parties or gatherings are permitted in guest rooms. A fee of $500 will be assessed for violations.</li>
          <li>No cooking in guest rooms unless the room is equipped with a kitchenette. A cleaning fee of $300 applies for violations.</li>
          <li>Visitors must depart by 9:00 PM. Unregistered overnight guests are not permitted.</li>
        </ul>
      </section>

      <section>
        <p class="font-body text-xs uppercase tracking-[0.25em] text-fox-orange mb-4 font-medium">07</p>
        <h2 class="font-display font-light text-3xl md:text-4xl mb-6 leading-tight">Damages &amp; Cleaning</h2>
        <ul class="font-body text-base leading-relaxed space-y-3 text-fox-brown font-light">
          <li>Guests are responsible for any damage to the room, furniture, linens, or property during their stay.</li>
          <li>Damages will be assessed and charged to the card on file at replacement cost, which may include labor.</li>
          <li>Excessively soiled linens, carpets, or furniture may incur additional deep-cleaning fees.</li>
        </ul>
      </section>

      <section>
        <p class="font-body text-xs uppercase tracking-[0.25em] text-fox-orange mb-4 font-medium">08</p>
        <h2 class="font-display font-light text-3xl md:text-4xl mb-6 leading-tight">Housekeeping</h2>
        <ul class="font-body text-base leading-relaxed space-y-3 text-fox-brown font-light">
          <li>For stays of two nights or fewer, daily housekeeping is not provided. Fresh towels and toiletries are available at the front desk upon request.</li>
          <li>For stays of three or more nights, rooms are serviced on the third day.</li>
          <li>Extended stays of seven or more nights receive weekly housekeeping on a designated day.</li>
        </ul>
      </section>

      <section>
        <p class="font-body text-xs uppercase tracking-[0.25em] text-fox-orange mb-4 font-medium">09</p>
        <h2 class="font-display font-light text-3xl md:text-4xl mb-6 leading-tight">Lost &amp; Found</h2>
        <ul class="font-body text-base leading-relaxed space-y-3 text-fox-brown font-light">
          <li>Items left behind will be held for 30 days. Please call <a href="tel:+16037884921" class="text-fox-red hover:text-deep-red border-b border-fox-orange">(603) 788&#8209;4921</a> to inquire.</li>
          <li>Shipping of lost items is available at the guest&rsquo;s expense.</li>
        </ul>
      </section>

      <section>
        <p class="font-body text-xs uppercase tracking-[0.25em] text-fox-orange mb-4 font-medium">10</p>
        <h2 class="font-display font-light text-3xl md:text-4xl mb-6 leading-tight">Illness &amp; Public Health</h2>
        <p class="font-body text-base leading-relaxed text-fox-brown font-light">
          In the event of a public health emergency, Red Fox Inn reserves the right to modify check-in procedures, housekeeping schedules, and occupancy limits in accordance with state and local health guidelines.
        </p>
      </section>

      <section>
        <p class="font-body text-xs uppercase tracking-[0.25em] text-fox-orange mb-4 font-medium">11</p>
        <h2 class="font-display font-light text-3xl md:text-4xl mb-6 leading-tight">Liability</h2>
        <ul class="font-body text-base leading-relaxed space-y-3 text-fox-brown font-light">
          <li>Red Fox Inn is not responsible for lost, stolen, or damaged personal property.</li>
          <li>Guests assume all risks associated with the use of outdoor amenities including fire pits, patios, and parking areas.</li>
        </ul>
      </section>

      <div class="pt-12 border-t border-fox-amber/40 text-center">
        <p class="font-body text-sm text-warm-gray font-light">
          Questions? Call us at <a href="tel:+16037884921" class="text-fox-red hover:text-deep-red border-b border-fox-orange">(603) 788&#8209;4921</a> or email <a href="mailto:stay@redfoxinnnh.com" class="text-fox-red hover:text-deep-red border-b border-fox-orange">stay@redfoxinnnh.com</a>.
        </p>
      </div>
    </div>

  </main>
</BaseLayout>
