---
import BaseLayout from '../layouts/BaseLayout.astro';

const brands = [
  'Drew Estate',
  'Dunbarton',
  'My Father’s Promise',
  'Ashton',
  'Rocky Patel',
  'A. Fuente',
  'Perdomo',
  'De Leon Cigars',
  '7-20-4',
];

const duskSchema = {
  '@context': 'https://schema.org',
  '@type': 'BarOrPub',
  '@id': 'https://redfoxinnnh.com/the-dusk/#lounge',
  name: 'The Dusk',
  alternateName: 'The Dusk Cigar Lounge at Red Fox Inn',
  description: 'Cigar lounge inside Red Fox Inn — when the fox emerges. Walk-in humidor with Drew Estate, A. Fuente, Rocky Patel, Perdomo, and more. Top-shelf bourbon. Leather chairs.',
  url: 'https://redfoxinnnh.com/the-dusk/',
  telephone: '+1-603-788-4921',
  servesCuisine: 'Cigars, Bourbon, Cocktails',
  priceRange: '$$$',
  acceptsReservations: false,
  parentOrganization: { '@id': 'https://redfoxinnnh.com/#hotel' },
  containedInPlace: { '@id': 'https://redfoxinnnh.com/#hotel' },
  address: {
    '@type': 'PostalAddress',
    streetAddress: '112 Main Street',
    addressLocality: 'Lancaster',
    addressRegion: 'NH',
    postalCode: '03584',
    addressCountry: 'US',
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Thursday', 'Friday', 'Saturday', 'Sunday', 'Monday'],
      opens: '14:00',
      closes: '22:00',
    },
  ],
};
---
<BaseLayout
  title="The Dusk &mdash; Cigar Lounge | Red Fox Inn, Lancaster NH"
  description="When the fox emerges. Premium cigars, walk-in humidor, top-shelf bourbon. Drew Estate, A. Fuente, Rocky Patel, and more at Red Fox Inn in Lancaster, NH."
  transparentHeader
  jsonLd={duskSchema}
>
  <main id="main-content">

    <!-- Hero -->
    <section class="relative bg-night text-snow px-6 py-40 md:py-56 overflow-hidden -mt-[88px] pt-[160px] md:pt-[200px]">
      <img
        src="/images/property/the-dusk-1600.webp"
        srcset="/images/property/the-dusk-800.webp 800w, /images/property/the-dusk-1600.webp 1000w"
        sizes="100vw"
        alt="The Dusk cigar lounge at Red Fox Inn — leather chairs and a quiet conversation space lit warm at dusk"
        width="1000"
        height="750"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-night/70"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,transparent_25%,rgba(28,20,16,0.75)_100%)]"></div>
      <div class="relative z-10 max-w-4xl mx-auto text-center">
        <p class="font-body text-xs uppercase tracking-[0.4em] text-fox-amber mb-10 font-medium">
          The Lounge
        </p>
        <h1 class="font-display font-light text-6xl md:text-8xl lg:text-[7rem] leading-[1.05] mb-10 text-snow drop-shadow-[0_2px_24px_rgba(28,20,16,0.8)]">
          The Dusk.
        </h1>
        <p class="font-display font-light italic text-xl md:text-2xl text-fox-amber max-w-3xl mx-auto leading-[1.5] drop-shadow-[0_1px_12px_rgba(28,20,16,0.7)]">
          When the fox emerges.
        </p>
      </div>
    </section>

    <!-- Body copy -->
    <section class="bg-snow px-6 py-24 md:py-32">
      <div class="max-w-3xl mx-auto">
        <div class="font-body font-light text-lg md:text-xl text-fox-brown leading-[1.75] space-y-8">
          <p>
            Dusk is the hour when foxes emerge &mdash; that liminal edge between day and night when the world goes quiet and the fire gets lit. The Dusk is our cigar lounge, and it lives in that same space between the day you had and the night ahead.
          </p>
          <p>
            Settle into leather chairs with a quality cigar and a top-shelf bourbon. Peruse our walk-in humidor and select from premium sticks &mdash; Drew Estate, Dunbarton, My Father&rsquo;s Promise, Ashton, Rocky Patel, A. Fuente, Perdomo. Newcomers <em class="font-display">De Leon Cigars</em> and the reinvented <em class="font-display">7-20-4</em> line from our very own New Hampshire.
          </p>
          <p class="font-display italic text-2xl md:text-3xl text-fox-red leading-[1.4] pt-4">
            You start the evening at <a href="/the-den/" class="border-b border-fox-orange hover:text-deep-red hover:border-deep-red transition-colors">The Den</a>. You finish it at The Dusk.
          </p>
        </div>
      </div>
    </section>

    <!-- Why the name -->
    <section class="bg-fox-cream px-6 py-24 md:py-32">
      <div class="max-w-5xl mx-auto grid md:grid-cols-[1fr_2fr] gap-10 md:gap-16 items-start">
        <div>
          <p class="font-body text-xs uppercase tracking-[0.3em] text-fox-red mb-3 font-medium">
            Why &ldquo;The Dusk&rdquo;
          </p>
          <p class="font-display font-light text-3xl md:text-4xl leading-[1.1] text-fox-brown">
            The hour the fox<br />gets to work.
          </p>
        </div>
        <div class="font-display font-light italic text-xl md:text-2xl text-fox-brown leading-[1.55] border-l-2 border-fox-orange pl-8 md:pl-10">
          <p>
            &ldquo;Dusk is when foxes hunt. It&rsquo;s the edge between daylight and dark, when everything gets quieter and the fire gets warmer. We named our cigar lounge The Dusk because it&rsquo;s where your evening deepens &mdash; from cocktails to bourbon, from conversation to contemplation.&rdquo;
          </p>
        </div>
      </div>
    </section>

    <!-- Brand strip -->
    <section class="bg-snow px-6 py-20 md:py-24">
      <div class="max-w-5xl mx-auto">
        <p class="font-body text-xs uppercase tracking-[0.3em] text-fox-red mb-10 font-medium text-center">In the Humidor</p>
        <div class="flex flex-wrap justify-center gap-x-10 gap-y-6">
          {brands.map((b) => (
            <span class="font-display font-light text-2xl md:text-3xl text-fox-brown">{b}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- Hours -->
    <section class="bg-night text-snow px-6 py-20 md:py-24">
      <div class="max-w-3xl mx-auto grid md:grid-cols-2 gap-12 md:gap-16">
        <div>
          <p class="font-body text-xs uppercase tracking-[0.3em] text-fox-amber mb-5 font-medium">Hours</p>
          <p class="font-display font-light text-2xl md:text-3xl leading-snug text-fox-amber mb-3">Thursday &ndash; Monday</p>
          <p class="font-body font-light text-lg text-fox-cream/85">2:00 &ndash; 10:00 PM</p>
          <p class="font-body text-xs uppercase tracking-[0.2em] text-fox-cream/60 mt-6 font-medium">21+ only</p>
        </div>
        <div>
          <p class="font-body text-xs uppercase tracking-[0.3em] text-fox-amber mb-5 font-medium">Find Us</p>
          <p class="font-body font-light text-lg text-fox-cream leading-relaxed">
            Inside Red Fox Inn<br />112 Main Street<br />Lancaster, NH 03584
          </p>
          <p class="font-body text-sm mt-4">
            <a href="tel:+16037884921" class="text-fox-amber hover:text-snow border-b border-fox-orange">(603) 788&#8209;4921</a>
          </p>
        </div>
      </div>
    </section>

    <!-- Cross-sell to The Den -->
    <section class="bg-fox-cream px-6 py-20 md:py-28">
      <div class="max-w-4xl mx-auto text-center">
        <p class="font-body text-xs uppercase tracking-[0.3em] text-fox-red mb-6 font-medium">Next Door</p>
        <h2 class="font-display font-light italic text-3xl md:text-5xl leading-[1.15] mb-8">
          Start the evening<br />at The Den.
        </h2>
        <p class="font-body font-light text-base md:text-lg text-warm-gray leading-relaxed mb-10 max-w-xl mx-auto">
          Classic cocktails in a jazz-and-velvet setting. Pick up a cigar from the humidor on your way through.
        </p>
        <a href="/the-den/" class="font-body inline-block px-10 py-4 bg-fox-red text-snow text-sm font-medium tracking-[0.15em] uppercase hover:bg-deep-red transition-colors">
          Visit The Den
        </a>
      </div>
    </section>

  </main>
</BaseLayout>
