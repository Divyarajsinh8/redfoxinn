---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface QuickFact {
  label: string;
  value: string;
  href?: string;
}

interface Props {
  title: string;
  dek: string;
  publishedDate: string; // ISO e.g. "2026-05-03"
  readMin: number;
  category: string;
  quickFacts: QuickFact[];
  metaTitle: string;
  metaDescription: string;
  /** Optional shortened breadcrumb label. Falls back to title. */
  breadcrumbLabel?: string;
}

const {
  title,
  dek,
  publishedDate,
  readMin,
  category,
  quickFacts,
  metaTitle,
  metaDescription,
  breadcrumbLabel,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, 'https://redfoxinnnh.com').toString();

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: metaDescription,
  datePublished: publishedDate,
  dateModified: publishedDate,
  author: { '@type': 'Organization', name: 'Red Fox Inn', url: 'https://redfoxinnnh.com' },
  publisher: {
    '@type': 'Organization',
    name: 'Red Fox Inn',
    logo: {
      '@type': 'ImageObject',
      url: 'https://redfoxinnnh.com/images/brand/fox-logo.png',
    },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  articleSection: category,
};

const dateFormatted = new Date(publishedDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<BaseLayout
  title={metaTitle}
  description={metaDescription}
  transparentHeader
  jsonLd={articleSchema}
>
  <main id="main-content">

    <!-- Hero -->
    <section class="relative bg-fox-brown text-snow px-6 py-32 md:py-44 overflow-hidden -mt-[88px] pt-[140px] md:pt-[180px]">
      <div class="absolute inset-0 bg-gradient-to-br from-night via-fox-brown to-deep-red/60"></div>
      <div class="relative z-10 max-w-4xl mx-auto">
        <div class="mb-8">
          <Breadcrumbs
            theme="light-on-dark"
            items={[
              { label: 'Journal', href: '/journal/' },
              { label: breadcrumbLabel ?? title },
            ]}
          />
        </div>
        <p class="font-body text-[0.7rem] md:text-xs uppercase tracking-[0.35em] text-fox-orange mb-8 font-medium">
          {category} <span class="text-fox-cream/50 mx-2">·</span> {dateFormatted} <span class="text-fox-cream/50 mx-2">·</span> {readMin} min read
        </p>
        <h1 class="font-display font-light text-4xl md:text-6xl lg:text-7xl leading-[1.1] mb-8 text-snow">
          {title}
        </h1>
        <p class="font-display font-light italic text-xl md:text-2xl text-fox-cream max-w-3xl leading-[1.5]">
          {dek}
        </p>
      </div>
    </section>

    <!-- Body + sticky sidebar -->
    <section class="bg-snow px-6 py-20 md:py-24">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-[1fr_320px] gap-12 lg:gap-20">

        <article class="journal-prose">
          <slot />
        </article>

        <aside class="lg:sticky lg:top-24 self-start">
          <div class="bg-fox-cream p-7 md:p-8 border-l-2 border-fox-orange">
            <p class="font-body text-xs uppercase tracking-[0.25em] text-fox-red mb-5 font-medium">Quick Facts</p>
            <dl class="space-y-4">
              {quickFacts.map((f) => (
                <div>
                  <dt class="font-body text-[0.7rem] uppercase tracking-[0.2em] text-warm-gray font-medium mb-1">{f.label}</dt>
                  <dd class="font-body font-light text-base text-fox-brown leading-snug">
                    {f.href ? (
                      <a href={f.href} target="_blank" rel="noopener noreferrer" class="border-b border-fox-orange hover:text-fox-red transition-colors">
                        {f.value} &nearr;
                      </a>
                    ) : f.value}
                  </dd>
                </div>
              ))}
            </dl>
          </div>

          <div class="mt-6 bg-fox-brown text-snow p-7">
            <p class="font-body text-xs uppercase tracking-[0.25em] text-fox-orange mb-3 font-medium">Stay With Us</p>
            <p class="font-display font-light text-2xl mb-5 leading-snug">A 27-room inn at 112 Main Street.</p>
            <a href="/book/" class="font-body inline-block w-full text-center px-6 py-3 bg-fox-red text-snow text-xs font-medium tracking-[0.15em] uppercase hover:bg-deep-red transition-colors">
              Check Availability
            </a>
            <a href="tel:+16037884921" class="font-body block text-center mt-3 text-sm text-fox-cream hover:text-fox-amber transition-colors">
              (603) 788&#8209;4921
            </a>
          </div>
        </aside>

      </div>
    </section>

    <!-- More journal -->
    <section class="bg-fox-cream px-6 py-16 md:py-20">
      <div class="max-w-6xl mx-auto text-center">
        <p class="font-body text-xs uppercase tracking-[0.3em] text-fox-red mb-6 font-medium">Read More</p>
        <a href="/journal/" class="font-display font-light italic text-3xl md:text-4xl text-fox-brown hover:text-fox-red transition-colors">
          Back to the Journal &rarr;
        </a>
      </div>
    </section>

  </main>
</BaseLayout>
